  "global_patterns": {
    "inclusive_indicators": [
      "incl", "inkl", "including", "inc", "TTC", "税込", "IVA inclusa"
    ],
    "exclusive_indicators": [
      "excl", "exkl", "excluding", "exc", "HT", "税抜", "IVA esclusa", "plus"
    ],
    "tax_line_indicators": [
      "tax:", "vat:", "tva:", "mwst:", "iva:", "消費税:", "sales tax:"
    ]
  },
  
  "calculation_methods": {
    "from_inclusive": {
      "formula": "tax_amount = total - (total / (1 + tax_rate/100))",
      "precision": 2
    },
    "from_exclusive": {
      "formula": "tax_amount = subtotal * (tax_rate/100)",
      "precision": 2
    },
    "validation": {
      "tolerance": 0.02,
      "rounding_check": true
    }
  },
  
  "confidence_scoring": {
    "factors": [
      {
        "name": "rate_match",
        "weight": 0.3,
        "description": "Tax rate matches country standards"
      },
      {
        "name": "keyword_match",
        "weight": 0.2,
        "description": "Tax keywords found"
      },
      {
        "name": "calculation_valid",
        "weight": 0.3,
        "description": "Tax calculation validates"
      },
      {
        "name": "format_match",
        "weight": 0.2,
        "description": "Format matches country patterns"
      }
    ],
    "thresholds": {
      "high": 0.8,
      "medium": 0.6,
      "low": 0.4
    }
  }
}