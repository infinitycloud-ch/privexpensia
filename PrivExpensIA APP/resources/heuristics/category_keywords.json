  "categorization_rules": {
    "priority_order": "lower_number_first",
    "keyword_matching": {
      "algorithm": "fuzzy_match",
      "threshold": 0.8,
      "case_sensitive": false
    },
    "multi_category_resolution": {
      "method": "highest_confidence",
      "confidence_calculation": [
        "keyword_matches * 0.4",
        "merchant_match * 0.4",
        "item_indicators * 0.2"
      ]
    },
    "fallback_category": "other"
  },
  
  "special_cases": {
    "split_bills": {
      "indicators": ["split", "shared", "divided", "partagé", "geteilt"],
      "handling": "prompt_user_for_percentage"
    },
    "tips": {
      "indicators": ["tip", "gratuity", "pourboire", "trinkgeld", "mancia"],
      "handling": "include_in_total"
    },
    "deposits": {
      "indicators": ["deposit", "caution", "kaution", "deposito"],
      "handling": "flag_as_refundable"
    }
  }
