  "countries": {
    "CH": {
      "name": "Switzerland",
      "tax_names": ["MwSt", "MWST", "TVA", "IVA"],
      "rates": {
        "standard": 8.1,
        "reduced": 2.5,
        "accommodation": 3.7
      },
      "detection_patterns": [
        "MwSt\\.?\\s*(\\d+[.,]\\d+)\\s*%",
        "TVA\\s*(\\d+[.,]\\d+)\\s*%",
        "IVA\\s*(\\d+[.,]\\d+)\\s*%",
        "inkl\\.?\\s*MwSt",
        "incl\\.?\\s*TVA"
      ],
      "rate_detection_rules": [
        {
          "rate": 2.5,
          "keywords": ["Lebensmittel", "Alimentari", "Food", "Nourriture", "Getränke"],
          "categories": ["food", "grocery"]
        },
        {
          "rate": 3.7,
