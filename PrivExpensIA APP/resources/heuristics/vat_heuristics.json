        },
        {
          "rate": 8.1,
          "keywords": ["Restaurant", "Service", "Transport"],
          "categories": ["restaurant", "transport", "other"]
        }
      ],
      "calculation": {
        "rounding": 0.05,
        "inclusive_default": true
      }
    },
    
